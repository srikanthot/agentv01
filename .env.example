# Azure OpenAI (GCC High)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.us/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=<chat-deployment-name>
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<chat-deployment-name>
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=<embeddings-deployment-name>

# Azure AI Search (GCC High) — EXISTING index
AZURE_SEARCH_ENDPOINT=https://<search>.search.azure.us
AZURE_SEARCH_API_KEY=<search-key>
AZURE_SEARCH_INDEX=rag-psegtechm-indexv01

# Index field mappings (match your actual index schema exactly)
SEARCH_CONTENT_FIELD=content
SEARCH_VECTOR_FIELD=contentVector
SEARCH_FILENAME_FIELD=source_file
SEARCH_PAGE_FIELD=page_number
SEARCH_CHUNK_ID_FIELD=chunk_id
SEARCH_URL_FIELD=source_url
SEARCH_SECTION_FIELD=

# Retrieval tuning
TOP_K=5
RETRIEVAL_CANDIDATES=15
VECTOR_K=50

# Retrieval quality
USE_SEMANTIC_RERANKER=false
SEMANTIC_CONFIG_NAME=default
QUERY_LANGUAGE=en-us
MIN_RESULTS=2
MIN_AVG_SCORE=0.02
DIVERSITY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=2
DOMINANT_SOURCE_SCORE_RATIO=1.5
MAX_CHUNKS_DOMINANT_SOURCE=4
SCORE_GAP_MIN_RATIO=0.55
TRACE_MODE=true

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Frontend
BACKEND_URL=http://localhost:8000
